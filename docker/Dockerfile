# =============================================================================
# Builder Stage
# =============================================================================
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS builder

WORKDIR /app

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# -----------------------------------------------------------------------------
# Copy dependency files first (maximize Docker cache)
# -----------------------------------------------------------------------------
COPY pyproject.toml uv.lock README.md ./

# Install third-party dependencies only
RUN uv sync \
    --frozen \
    --no-dev \
    --no-install-project

# -----------------------------------------------------------------------------
# Copy project source
# -----------------------------------------------------------------------------
COPY . .

# Install the project itself
RUN uv sync \
    --frozen \
    --no-dev


# =============================================================================
# Runtime Stage
# =============================================================================
FROM python:3.12-slim-bookworm AS runtime

WORKDIR /app

# -----------------------------------------------------------------------------
# Python runtime configuration
# -----------------------------------------------------------------------------
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PATH="/app/.venv/bin:$PATH"

# -----------------------------------------------------------------------------
# OCI Image Metadata
# -----------------------------------------------------------------------------
LABEL org.opencontainers.image.title="MedRAG"
LABEL org.opencontainers.image.description="Production-grade Medical Retrieval-Augmented Generation System"
LABEL org.opencontainers.image.version="0.1.0"

# -----------------------------------------------------------------------------
# Create non-root user
# -----------------------------------------------------------------------------
RUN groupadd --system medrag && \
    useradd \
        --system \
        --gid medrag \
        --create-home \
        medrag

# -----------------------------------------------------------------------------
# Copy application from builder
# -----------------------------------------------------------------------------
COPY --from=builder /app /app

# -----------------------------------------------------------------------------
# Switch to non-root user
# -----------------------------------------------------------------------------
USER medrag

# -----------------------------------------------------------------------------
# Application Port
# -----------------------------------------------------------------------------
EXPOSE 8000

# -----------------------------------------------------------------------------
# Application Startup
# -----------------------------------------------------------------------------
CMD ["/app/scripts/start.sh"]